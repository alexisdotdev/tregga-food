<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDisplayName</key>
	<string>Tregga Food</string>
	<key>GOOGLE_MAPS_API_KEY</key>
	<string>$(GOOGLE_MAPS_API_KEY)</string>
	<key>GOOGLE_MAPS_MAP_ID</key>
	<string>$(GOOGLE_MAPS_MAP_ID)</string>
	<key>NSCameraUsageDescription</key>
	<string>Tregga necesita la cámara para que tomes foto de tu INE, vehículo y recibos de pedidos.</string>
	<key>NSFaceIDUsageDescription</key>
	<string>Tregga usa Face ID para desbloquear la app y proteger tu cuenta de repartidor.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Tregga necesita tu ubicación para guiarte al negocio y al cliente durante tus entregas.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Tregga necesita acceso a fotos para que puedas subir tu INE, foto de tu vehículo y recibos.</string>
	<key>SupabaseAnonKey</key>
	<string>$(SUPABASE_ANON_KEY)</string>
	<key>SupabaseURL</key>
	<string>$(SUPABASE_URL)</string>
	<key>UILaunchScreen</key>
	<dict>
		<key>UIColorName</key>
		<string>LaunchBackground</string>
	</dict>
</dict>
</plist>
